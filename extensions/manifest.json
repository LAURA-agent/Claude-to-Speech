{
  "manifest_version": 3,
  "name": "Claude-to-Speech",
  "version": "1.0",
  "description": "Bring Claude to life with ElevenLabs!",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.claude.ai/*"],
      "js": [
        "config/extension_config.js",
        "content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://*.claude.ai/*",
    "http://127.0.0.1:5000/*"
  ]
}
